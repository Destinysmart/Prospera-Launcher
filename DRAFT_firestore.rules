rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- PRIMITIVES ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 64 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isOwner(data) {
      return isSignedIn() && data.ownerId == request.auth.uid;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // --- VALIDATION HELPERS ---

    function isValidResident(data) {
      return data.keys().hasAll(['id', 'name', 'email', 'status', 'ownerId', 'createdAt'])
        && data.keys().size() == 6
        && data.id is string && data.id.size() <= 64
        && data.name is string && data.name.size() >= 2 && data.name.size() <= 100
        && data.email is string && data.email.size() <= 100
        && data.status in ['pending', 'processing', 'active', 'rejected']
        && data.ownerId == request.auth.uid
        && data.createdAt == request.time;
    }

    function isValidEntity(data) {
      return data.keys().hasAll(['id', 'companyName', 'email', 'framework', 'status', 'ownerId', 'createdAt'])
        && data.keys().size() == 7
        && data.id is string && data.id.size() <= 64
        && data.companyName is string && data.companyName.size() >= 2 && data.companyName.size() <= 100
        && data.email is string && data.email.size() <= 100
        && data.framework in ['Common-Law', 'Fintech-Reg-A', 'Financial-Reg-A']
        && data.status in ['pending', 'processing', 'active', 'rejected']
        && data.ownerId == request.auth.uid
        && data.createdAt == request.time;
    }

    // --- COLLECTIONS ---

    match /residents/{residentId} {
      allow get: if isOwner(existing()) || isAdmin();
      allow list: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
      
      allow create: if isVerified() 
        && isValidId(residentId)
        && residentId == incoming().id
        && isValidResident(incoming())
        && incoming().status == 'pending';

      allow update: if isSignedIn() && (
        // Admin can update anything
        isAdmin() || 
        // User can only update if it's their own and only specific fields (though v1.0 doesn't need this yet)
        (isOwner(existing()) && isValidResident(incoming()) && incoming().status == existing().status)
      );

      allow delete: if isAdmin();
    }

    match /corporate_entities/{entityId} {
      allow get: if isOwner(existing()) || isAdmin();
      allow list: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());

      allow create: if isVerified()
        && isValidId(entityId)
        && entityId == incoming().id
        && isValidEntity(incoming())
        && incoming().status == 'pending';

      allow update: if isSignedIn() && (
        isAdmin() ||
        (isOwner(existing()) && isValidEntity(incoming()) && incoming().status == existing().status)
      );

      allow delete: if isAdmin();
    }

    // Admins collection - only readable by signed in (optional, usually fully hidden)
    match /admins/{adminId} {
      allow read: if isSignedIn() && request.auth.uid == adminId;
    }
  }
}
