rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- PRIMITIVES ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 64 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isOwner(data) {
      return isSignedIn() && data.ownerId == request.auth.uid;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // --- VALIDATION HELPERS ---

    function isValidResident(data) {
      return data.keys().hasAll(['id', 'ownerId', 'status', 'prosperaData', 'updatedAt'])
        && data.id is string && data.id.size() <= 64
        && data.status in ['pending', 'processing', 'active', 'rejected', 'loading']
        && data.ownerId == request.auth.uid;
    }

    function isValidEntity(data) {
      return data.keys().hasAll(['id', 'ownerId', 'status', 'companyName', 'email', 'framework', 'amount', 'updatedAt', 'purpose'])
        && data.id is string && data.id.size() <= 64
        && data.status in ['pending', 'pending_signature', 'pending_payment', 'processing', 'active', 'rejected']
        && data.companyName is string && data.companyName.size() >= 2 && data.companyName.size() <= 100
        && data.framework is string
        && data.amount is number
        && data.ownerId == request.auth.uid;
    }

    // --- COLLECTIONS ---

    match /residents/{residentId} {
      allow get: if isSignedIn() && (request.auth.uid == residentId || (resource != null && resource.data.ownerId == request.auth.uid) || isAdmin());
      allow list: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
      
      allow create: if isVerified() 
        && isValidId(residentId)
        && residentId == incoming().id
        && isValidResident(incoming())
        && incoming().status == 'pending';

      allow update: if isSignedIn() && (
        isAdmin() || 
        (resource != null && resource.data.ownerId == request.auth.uid && isValidResident(incoming()) && incoming().status == existing().status)
      );

      allow delete: if isAdmin();
    }

    match /corporate_entities/{entityId} {
      allow get: if isSignedIn() && (resource == null || resource.data.ownerId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());

      allow create: if isVerified()
        && isValidId(entityId)
        && entityId == incoming().id
        && isValidEntity(incoming())
        && incoming().status == 'pending_payment';

      allow update: if isSignedIn() && (
        isAdmin() ||
        (resource != null && resource.data.ownerId == request.auth.uid && isValidEntity(incoming()) && incoming().status == existing().status)
      );

      allow delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn() && request.auth.uid == adminId;
      allow write: if false;
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /webhooks/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /invoices_history/{invoiceId} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow write: if isSignedIn() && request.auth.uid == incoming().ownerId;
    }
    match /referrals/{referralId} {
      allow read: if isSignedIn() && resource.data.referrer_id == request.auth.uid;
      allow write: if false; // Only backend writes referrals
    }
  }
}
